{
  "name": "flowtest",
  "version": "0.1.0",
  "description": "Visual Playwright recording and execution tool",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "playwright-core": "^1.44.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "reactflow": "^11.11.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "electron-vite": "^2.1.0",
    "typescript": "^5.4.0"
  },
  "build": {
    "extends": null,
    "productName": "FlowTest",
    "appId": "com.flowtest.app",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "!node_modules/**"
    ]
  }
}
